{
  "name": "@rootherald/angular",
  "version": "0.1.0",
  "description": "Angular adapter for Root Herald device attestation SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rootherald/contracts": "workspace:*",
    "@rootherald/js": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/core": "^17.3.0",
    "@types/node": "^22.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zone.js": "^0.14.0"
  }
}

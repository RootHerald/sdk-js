{
  "name": "@rootherald/browser",
  "version": "0.1.0-alpha.0",
  "description": "Browser SDK for Root Herald — brokers device-evidence collection through the RootHerald browser extension and exposes cold-start client detection",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rootherald/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RootHerald/sdk-js.git",
    "directory": "packages/browser"
  },
  "homepage": "https://github.com/RootHerald/sdk-js/tree/main/packages/browser#readme",
  "bugs": {
    "url": "https://github.com/RootHerald/sdk-js/issues"
  }
}
